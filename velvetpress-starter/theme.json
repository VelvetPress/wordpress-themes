{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 3,
  "settings": {
    "color": {
      "palette": [
        { "slug": "primary", "color": "#6C3CE1", "name": "Primary" },
        { "slug": "primary-light", "color": "#8B5CF6", "name": "Primary Light" },
        { "slug": "secondary", "color": "#0EA5E9", "name": "Secondary" },
        { "slug": "dark", "color": "#0F172A", "name": "Dark" },
        { "slug": "light", "color": "#F8FAFC", "name": "Light" },
        { "slug": "muted", "color": "#94A3B8", "name": "Muted" },
        { "slug": "white", "color": "#FFFFFF", "name": "White" }
      ]
    },
    "typography": {
      "fontFamilies": [
        {
          "fontFamily": "-apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, sans-serif",
          "slug": "system",
          "name": "System"
        }
      ]
    },
    "spacing": {
      "units": ["px", "rem", "vh", "vw", "%"]
    },
    "layout": {
      "contentSize": "800px",
      "wideSize": "1200px"
    }
  },
  "styles": {
    "color": {
      "background": "#FFFFFF",
      "text": "#0F172A"
    },
    "typography": {
      "fontFamily": "-apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, sans-serif",
      "lineHeight": "1.6"
    },
    "elements": {
      "link": {
        "color": { "text": "#6C3CE1" },
        ":hover": { "color": { "text": "#8B5CF6" } }
      },
      "button": {
        "color": { "background": "#6C3CE1", "text": "#FFFFFF" },
        "border": { "radius": "8px" },
        "typography": { "fontWeight": "600" },
        ":hover": { "color": { "background": "#8B5CF6" } }
      },
      "heading": {
        "typography": { "fontWeight": "700", "lineHeight": "1.2" }
      }
    }
  }
}
